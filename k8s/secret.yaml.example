apiVersion: v1
kind: Secret
metadata:
  name: allright-secrets
type: Opaque
stringData:
  DB_USERNAME: postgres
  DB_PASSWORD: change-me-db-password
  DB_DATABASE: postgres
  JWT_SECRET: change-me-jwt-secret-at-least-32-characters-long
  ZKP_PEPPER: change-me-zkp-pepper-at-least-32-characters-long
  METRICS_TOKEN: change-me-metrics-token-at-least-16-chars
