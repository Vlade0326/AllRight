# Database
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=postgres
DB_PASSWORD=root
DB_DATABASE=postgres
DB_SYNCHRONIZE=true
DB_MIGRATIONS_RUN=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# API
API_PORT=3000
PORT=3000
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=60m

# ZKP / Geofence
ZKP_ADAPTER=commitment
ZKP_PEPPER=allright-zkp-pepper-change-me
GEOFENCE_LAT=3.4516
GEOFENCE_LON=-76.5320
GEOFENCE_RADIUS_KM=0.5

# Rate limiting (Redis)
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_SEC=60
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_LOGIN_WINDOW_SEC=300

# Password reset (Redis token TTL)
PASSWORD_RESET_TTL_SEC=900

# Observability
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
