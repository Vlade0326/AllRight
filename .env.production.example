# Production — copy to .env and replace ALL secrets before deploy
NODE_ENV=production

# Database (use strong credentials)
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=REPLACE_WITH_STRONG_DB_PASSWORD
DB_DATABASE=postgres
DB_SYNCHRONIZE=false
DB_MIGRATIONS_RUN=true

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# API
API_PORT=3000
JWT_SECRET=REPLACE_WITH_RANDOM_32_CHAR_MIN_SECRET
JWT_EXPIRES_IN=60m

# ZKP — Groth16 en producción
ZKP_ADAPTER=snarkjs
ZKP_ARTIFACTS_ENV=prod
ZKP_PEPPER=REPLACE_WITH_RANDOM_ZKP_PEPPER_32_CHARS

# Geofence (Cali default)
GEOFENCE_LAT=3.4516
GEOFENCE_LON=-76.5320
GEOFENCE_RADIUS_KM=0.5

# Rate limiting (Redis)
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_SEC=60
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_LOGIN_WINDOW_SEC=300

# App URL (links de reset password)
APP_URL=https://REPLACE_WITH_PUBLIC_HOST:3443

# Email — sin SMTP_HOST = log en consola. Guía: Diagramas/SMTP-SETUP.md
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=AllRight <noreply@tudominio.com>
# PANIC_NOTIFY_EMAIL=ops@tudominio.com

# Metrics (obligatorio ≥16 chars en producción)
# METRICS_TOKEN=REPLACE_WITH_RANDOM_METRICS_TOKEN
# METRICS_ALLOW_PRIVATE=true

# Observability
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_USER=admin
GRAFANA_PASSWORD=REPLACE_WITH_STRONG_GRAFANA_PASSWORD
