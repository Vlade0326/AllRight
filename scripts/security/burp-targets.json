{
  "project": "AllRight API",
  "baseUrl": "http://127.0.0.1:3000",
  "scope": {
    "include": [
      "/auth/*",
      "/users",
      "/location/*",
      "/security/*",
      "/proximity/*",
      "/notifications/*",
      "/health",
      "/health/ready",
      "/metrics"
    ]
  },
  "endpoints": [
    {
      "method": "POST",
      "path": "/auth/login",
      "body": { "email": "usuario@allright.app", "password": "AllRight2026!Secure" },
      "tests": ["sql_injection", "brute_force", "rate_limit_429"]
    },
    {
      "method": "POST",
      "path": "/auth/forgot-password",
      "body": { "email": "usuario@allright.app" },
      "tests": ["user_enumeration", "token_leak"]
    },
    {
      "method": "POST",
      "path": "/auth/reset-password",
      "body": { "token": "INVALID", "newPassword": "NewPass2026!" },
      "tests": ["token_bruteforce", "weak_password"]
    },
    {
      "method": "POST",
      "path": "/auth/change-password",
      "auth": "Bearer",
      "body": { "currentPassword": "AllRight2026!Secure", "newPassword": "NewPass2026!Secure" },
      "tests": ["auth_bypass", "idor"]
    },
    {
      "method": "POST",
      "path": "/users",
      "body": { "email": "fuzz@test.com", "password": "Test1234!", "role": "user" },
      "tests": ["mass_assignment", "xss_stored"]
    },
    {
      "method": "POST",
      "path": "/location/prove",
      "auth": "Bearer",
      "body": { "lat": 3.4516, "lon": -76.5320 },
      "tests": ["geofence_bypass", "replay"]
    },
    {
      "method": "POST",
      "path": "/location/verify",
      "auth": "Bearer",
      "body": { "proof": {}, "payload": {} },
      "tests": ["zkp_tampering", "invalid_proof"]
    },
    {
      "method": "GET",
      "path": "/location/history",
      "auth": "Bearer",
      "tests": ["auth_bypass"]
    },
    {
      "method": "POST",
      "path": "/security/panic",
      "auth": "Bearer",
      "body": {},
      "tests": ["auth_bypass", "rate_limit"]
    },
    {
      "method": "GET",
      "path": "/security/panic/active",
      "auth": "Bearer",
      "tests": ["auth_bypass", "jwt_none", "jwt_tamper"]
    },
    {
      "method": "GET",
      "path": "/proximity/zones",
      "auth": "Bearer",
      "tests": ["auth_bypass"]
    },
    {
      "method": "POST",
      "path": "/proximity/report",
      "auth": "Bearer",
      "body": { "uuid": "f7826da6-4fa2-4e98-8024-bc5b71e0893e", "rssi": -55 },
      "tests": ["spoof_beacon", "auth_bypass"]
    },
    {
      "method": "POST",
      "path": "/proximity/gps",
      "auth": "Bearer",
      "body": { "lat": 3.4516, "lon": -76.5320 },
      "tests": ["spoof_location"]
    },
    {
      "method": "GET",
      "path": "/proximity/hybrid",
      "auth": "Bearer",
      "tests": ["auth_bypass"]
    },
    {
      "method": "GET",
      "path": "/notifications/vapid-public-key",
      "tests": ["info_disclosure"]
    },
    {
      "method": "GET",
      "path": "/metrics",
      "tests": ["info_disclosure"]
    }
  ],
  "intruderPayloads": {
    "sql": ["' OR '1'='1", "admin'--", "1; DROP TABLE users--"],
    "xss": ["<script>alert(1)</script>", "\"><img src=x onerror=alert(1)>"],
    "jwt": ["none_algorithm", "expired_token", "tampered_signature"]
  }
}
